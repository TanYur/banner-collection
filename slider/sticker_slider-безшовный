  <style>*{ box-sizing: border-box} html, body{ margin: 0; padding: 0; overflow-x: hidden} .slider{ position: sticky; top: 0; z-index: 11; width: 100%; max-width: 100%; overflow: hidden; background: transparent;margin-top: 1px} .slides{ display: flex; width: 100%; transition: transform 0.6s ease-in-out; will-change: transform; transform: translate3d(0, 0, 0); backface-visibility: hidden;transition-timing-function: transition-timing-function: cubic-bezier(0.45, 0.1, 0.15, 1);} .slide-item{ flex: 0 0 100%; width: 100%; max-width: 100%; display: block; line-height: 0} .darmowa-row{ width: 100%; display: flex; align-items: center; justify-content: center; text-decoration: none; color: #fff; font-family: var(--font-manrope, Arial, sans-serif)} .darmowa-row:hover{ text-decoration: none} .darmowa-container{ height: 32px; display: flex; align-items: center; justify-content: center; text-align: center; padding: 0 10px} .sticker-text{ color: #fff; font-size: 14px; letter-spacing: 1px; white-space: nowrap; font-weight: 300; margin: 0} .sticker-text-mobile{ display: none} @media (max-width: 1023px){ .sticker-text{ display: none} .sticker-text-mobile{ display: block; white-space: normal; letter-spacing: 1px; font-size: 12px}} .item-dzien-matki{ background: #9f010a} .item-travel{ background: #7b5534} .item-03{ background: #ff0000} .item-04{ background: #c3c3c3} </style>

        <div class="slider">
            <div class="slides">
                <a href="/produkty-dzien-matki" class="darmowa-row item-dzien-matki slide-item">
                    <div class="darmowa-container">
                        <p class="sticker-text">DZIEŃ MATKI - dodatkowe rabaty do 30% na torebki, buty</p>
                        <p class="sticker-text-mobile">DZIEŃ MATKI - dodatkowe rabaty do 30% </p>
                    </div>
                </a>

                <a href="/bagaz" class="darmowa-row item-travel slide-item">
                    <div class="darmowa-container">
                      <p class="sticker-text">EKSTRA rabat 25% na Kolekcję Travel przy zakupach za min. 249 zł </p>
                       <p class="sticker-text-mobile">EKSTRA rabat 25% na Kolekcję Travel</p>
                    </div>
                </a>

                <a href="/mezczyzna" class="darmowa-row item-03 slide-item">
                    <div class="darmowa-container">
                        <p class="sticker-text">Special Offer - bis zu 30% Extra-Rabatt auf Taschen, Schuhe </p>
                         <p class="sticker-text-mobile">Special Offer - bis zu 30% Extra-Rabatt</p>
                    </div>
                </a>

                <a href="/kobieta/torebki/plecaki-damskie" class="darmowa-row item-04 slide-item">
                    <div class="darmowa-container">
                        <p class="sticker-text">Special Offer – dodatečné slevy až 30 % na kabelky, boty </p>
                          <p class="sticker-text-mobile">Special Offer – dodatečné slevy až 30 %</p>
                    </div>
                </a>

            </div>
        </div>

        <script>
            const slider = document.querySelector('.slider');
            const slidesWrapper = document.querySelector('.slides');

            let slides = document.querySelectorAll('.slide-item');

            let currentIndex = 1;

            const intervalTime = 5850;

            const firstClone = slides[0].cloneNode(true);
            const lastClone = slides[slides.length - 1].cloneNode(true);

            firstClone.id = 'first-clone';
            lastClone.id = 'last-clone';

            slidesWrapper.appendChild(firstClone);
            slidesWrapper.prepend(lastClone);

            slides = document.querySelectorAll('.slide-item');

            function setPosition() {
                slidesWrapper.style.transform =
                    `translateX(-${currentIndex * 100}%)`;
            }

            setPosition();


            function moveToNextSlide() {
                if (currentIndex >= slides.length - 1) return;

                currentIndex++;

                slidesWrapper.style.transition =
                    'transform 0.6s ease-out .4s';

                setPosition();
            }

            function moveToPrevSlide() {
                if (currentIndex <= 0) return;

                currentIndex--;

                slidesWrapper.style.transition =
                  'transform 0.6s ease-out .6s';

                setPosition();
            }


            slidesWrapper.addEventListener('transitionend', () => {

                if (slides[currentIndex].id === 'first-clone') {

                    slidesWrapper.style.transition = 'none';
                    currentIndex = 1;
                    setPosition();
                }


                if (slides[currentIndex].id === 'last-clone') {

                    slidesWrapper.style.transition = 'none';
                    currentIndex = slides.length - 2;
                    setPosition();
                }
            });


            let sliderInterval = setInterval(() => {
                moveToNextSlide();
            }, intervalTime);



            slider.addEventListener('mouseenter', () => {
                clearInterval(sliderInterval);
            });

            slider.addEventListener('mouseleave', () => {

                sliderInterval = setInterval(() => {
                    moveToNextSlide();
                }, intervalTime);

            });
        </script>
